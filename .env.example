# ==============================================
# Fridge Recipe - Local Development Environment
# ==============================================
# Copy this file to .env and fill in the values
# cp .env.example .env

# ── Database (PostgreSQL) ────────────────────
DB_URL=jdbc:postgresql://localhost:5432/fridgerecipe
DB_USER=postgres
DB_PASSWORD=postgres
DB_MAX_POOL_SIZE=10

# ── Redis ────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT Authentication ───────────────────────
JWT_SECRET=dev-secret-change-in-production
JWT_ISSUER=fridge-recipe
JWT_AUDIENCE=fridge-recipe-app
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=14

# ── AI Service ───────────────────────────────
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_API_KEY=dev-internal-key

# ── Naver Clova OCR ──────────────────────────
CLOVA_OCR_API_URL=
CLOVA_OCR_SECRET_KEY=

# ── OpenAI (GPT-4o Vision) ───────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ── Server ───────────────────────────────────
SERVER_PORT=8080
